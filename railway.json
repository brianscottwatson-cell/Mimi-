{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && pip install -r claudebot/web/server/requirements.txt"
  },
  "deploy": {
    "startCommand": "python claudebot/web/server/start_railway.py",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
